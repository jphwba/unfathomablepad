{
    "manufacturer": "Jenish",
    "keyboard_name": "unfathomablepad",
    "maintainer": "jphwba",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "diode_direction": "ROW2COL",
    "url": "https://github.com/jphwba/unfathomablepad-firmware",
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": false,
        "nkro": true
    },
    "matrix_pins": {
        "cols": ["GP26", "GP27", "GP6"],
        "rows": ["GP29", "GP7"]
    },
    "encoder": {
        "rotary": [
            {"pin_a": "GP29", "pin_b": "GP28", "resolution": 4}
        ]
    },
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0000",
        "vid": "0xFEED"
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1}
            ]
        }
    }
}